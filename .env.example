# ==========================
# DATABASE (Neon PostgreSQL)
# ==========================
# URL kết nối PostgreSQL serverless trên Neon
# Copy giá trị này sang .env.local và điền thông tin thật
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>?sslmode=require

# ==========================
# JWT / Authentication
# ==========================
# Secret key dùng cho JWT token
JWT_SECRET=your_jwt_secret_here

# ==========================
# FRONTEND
# ==========================
# Biến môi trường có thể truy cập từ frontend (bắt đầu bằng NEXT_PUBLIC_)
NEXT_PUBLIC_API_BASE=http://localhost:3000/api
